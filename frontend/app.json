{
  "expo": {
    "name": "AUTONOME",
    "slug": "autonome",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "autonome",
    "icon": "./app/assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./app/assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FF00"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.autonome.app",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "autonome"
        ]
      }
    },
    "android": {
      "package": "com.autonome.app",
      "adaptiveIcon": {
        "foregroundImage": "./app/assets/images/android-icon-foreground.png",
        "backgroundColor": "#F8FF00"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "autonome",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./app/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "632f422c-9276-440f-8cad-1049eefd1fad"
      }
    },
    "owner": "sasdmis"
  }
}
